<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="16dp"
    app:cardBackgroundColor="#0D111A"
    app:cardCornerRadius="20dp"
    app:strokeColor="#33FF1744"
    app:strokeWidth="1dp"
    app:cardElevation="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZIXINE ENGINE"
            android:textColor="#FF1744"
            android:textSize="22sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.1" />

        <TextView
            android:id="@+id/dialog_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="STATUS: CHECKING..."
            android:textColor="#00E5FF"
            android:textSize="12sp"
            android:textStyle="bold"
            android:letterSpacing="0.2" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="#1AFFFFFF" />

        <TextView
            android:id="@+id/dialog_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#BBFFFFFF"
            android:textSize="14sp"
            android:lineSpacingExtra="6dp"
            android:text="Pesan panduan akan muncul di sini..." />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical">

            <Button
                android:id="@+id/btn_dialog_donate"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:text="DONASI / PASSKEY"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#1E2433"
                app:cornerRadius="12dp"
                android:visibility="gone"/>

            <Button
                android:id="@+id/btn_dialog_ok"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="10dp"
                android:text="MENGERTI"
                android:textColor="#0D111A"
                android:textStyle="bold"
                android:backgroundTint="#00E5FF"
                app:cornerRadius="12dp" />
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
