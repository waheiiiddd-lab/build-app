<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0E14"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="50dp"
        android:gravity="center"
        android:orientation="vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZIXINE"
            android:textColor="#FF1744"
            android:textSize="45sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.2"
            android:textStyle="bold" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="zixine elysium"
            android:textColor="#00E5FF"
            android:textSize="14sp"
            android:fontFamily="sans-serif-condensed-light" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/lock_overlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        app:cardBackgroundColor="#12161F"
        app:cardCornerRadius="20dp"
        app:strokeColor="#FF1744"
        app:strokeWidth="1dp"
        android:visibility="gone"
        android:elevation="10dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="center">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="DEVICE NOT SUPPORTED"
                android:textColor="#FF1744"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/input_code"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:hint="Input: 445456"
                android:textColor="#FFFFFF"
                android:textColorHint="#44FFFFFF"
                android:inputType="number"
                android:gravity="center"
                android:backgroundTint="#FF1744" />
            <Button
                android:id="@+id/btn_unlock"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="UNLOCK ZIXINE"
                android:backgroundTint="#FF1744" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/main_ui"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="horizontal">
        
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_perf"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="43dp"
            app:cardBackgroundColor="#12161F"
            app:strokeColor="#1E2433"
            app:strokeWidth="1dp">
            <TextView android:id="@+id/status_perf" android:layout_width="match_parent" android:layout_height="match_parent" android:text="OFF" android:textColor="#44FFFFFF" android:gravity="center" android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_gms"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="43dp"
            app:cardBackgroundColor="#12161F"
            app:strokeColor="#1E2433"
            app:strokeWidth="1dp">
            <TextView android:id="@+id/status_gms" android:layout_width="match_parent" android:layout_height="match_parent" android:text="OFF" android:textColor="#44FFFFFF" android:gravity="center" android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btn_extreme"
            android:layout_width="85dp"
            android:layout_height="85dp"
            android:layout_margin="8dp"
            app:cardCornerRadius="43dp"
            app:cardBackgroundColor="#12161F"
            app:strokeColor="#1E2433"
            app:strokeWidth="1dp">
            <TextView android:id="@+id/status_extreme" android:layout_width="match_parent" android:layout_height="match_parent" android:text="OFF" android:textColor="#44FFFFFF" android:gravity="center" android:textStyle="bold" />
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        app:cardBackgroundColor="#12161F"
        app:cardCornerRadius="32dp"
        app:strokeColor="#1E2433"
        app:strokeWidth="1dp">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btn_trigger"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="center"
                app:cardBackgroundColor="#1E2433"
                app:cardCornerRadius="24dp">
                <TextView android:id="@+id/arrow_text" android:layout_width="match_parent" android:layout_height="match_parent" android:text="▲" android:textColor="#FFFFFF" android:gravity="center" />
            </com.google.android.material.card.MaterialCardView>
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ZIXINE ELYSIUM"
                android:textColor="#00E5FF"
                android:layout_gravity="center"
                android:layout_marginTop="16dp"
                android:fontFamily="sans-serif-medium" />
            <TextView
                android:id="@+id/tutorial_view"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:text="TUTORIAL:\n1. Gunakan QS Tiles untuk aktivasi cepat.\n2. PERF: Optimize Hz/Touch.\n3. GMS KILL: Bekukan Google Services (pm disable).\n4. EXTREME: PERF+Suspend GMS+ZRAM OFF."
                android:textColor="#66FFFFFF"
                android:textSize="12sp"
                android:visibility="gone" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</RelativeLayout>
