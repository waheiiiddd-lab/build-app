<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_dark" android:padding="16dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical">
        
        <TextView 
            android:layout_width="wrap_content" 
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="zixine engine" 
            android:textColor="@color/accent_blue" 
            android:textSize="28sp" 
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp"
            app:cardBackgroundColor="@color/card_dark" app:cardCornerRadius="12dp" app:strokeColor="#30363D" app:strokeWidth="1dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <TextView android:id="@+id/tv_cpu_fps" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="System Info Loading..." android:textColor="#7D8590" />
                <TextView android:id="@+id/tv_battery_ram" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Hardware Info Loading..." android:textColor="#7D8590" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <GridLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:columnCount="2">
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_gms" android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:layout_margin="8dp" app:cardBackgroundColor="@color/btn_dongker" app:cardCornerRadius="16dp" android:clickable="true">
                <TextView android:id="@+id/txt_gms" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="⚡\nGMS" android:textColor="#FFF" android:textStyle="bold" android:textAlignment="center"/>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_extreme" android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:layout_margin="8dp" app:cardBackgroundColor="@color/btn_dongker" app:cardCornerRadius="16dp" android:clickable="true">
                <TextView android:id="@+id/txt_ext" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🔥\nEXTREME" android:textColor="#FFF" android:textStyle="bold" android:textAlignment="center"/>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_perf" android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:layout_margin="8dp" app:cardBackgroundColor="@color/btn_dongker" app:cardCornerRadius="16dp" android:clickable="true">
                <TextView android:id="@+id/txt_perf" android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="🚀\nPERF" android:textColor="#FFF" android:textStyle="bold" android:textAlignment="center"/>
            </com.google.android.material.card.MaterialCardView>
            <com.google.android.material.card.MaterialCardView android:id="@+id/card_monitor" android:layout_width="0dp" android:layout_height="110dp" android:layout_columnWeight="1" android:layout_margin="8dp" app:cardBackgroundColor="@color/btn_dongker" app:cardCornerRadius="16dp" android:clickable="true">
                <TextView android:layout_width="match_parent" android:layout_height="match_parent" android:gravity="center" android:text="📊\nMONITOR" android:textColor="#FFF" android:textStyle="bold" android:textAlignment="center"/>
            </com.google.android.material.card.MaterialCardView>
        </GridLayout>
    </LinearLayout>
</ScrollView>
