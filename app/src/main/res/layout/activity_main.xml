<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07090D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZIXINE"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENGINE CORE"
            android:textColor="#FF1744"
            android:textSize="12sp"
            android:letterSpacing="0.3"
            android:layout_marginBottom="30dp" />

        <LinearLayout
            android:id="@+id/layout_locked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">
            
            <EditText
                android:id="@+id/input_code"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:hint="ENTER PASSKEY"
                android:textColor="#FFFFFF"
                android:textColorHint="#44FFFFFF"
                android:backgroundTint="#FF1744"
                android:inputType="numberPassword"
                android:gravity="center"
                android:textSize="18sp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_unlock"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="20dp"
                android:text="UNLOCK SYSTEM"
                android:background="#FF1744"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_verified"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView android:text="RAM STATUS" android:textColor="#88FFFFFF" android:textSize="11sp" />
            <TextView android:id="@+id/tv_ram" android:text="..." android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="15dp" />

            <TextView android:text="ZRAM SIZE" android:textColor="#88FFFFFF" android:textSize="11sp" />
            <TextView android:id="@+id/tv_zram" android:text="..." android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="15dp" />

            <TextView android:text="ACTIVE GOVERNOR" android:textColor="#88FFFFFF" android:textSize="11sp" />
            <TextView android:id="@+id/tv_cpu" android:text="..." android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="15dp" />

            <TextView android:text="BATTERY LEVEL" android:textColor="#88FFFFFF" android:textSize="11sp" />
            <TextView android:id="@+id/tv_battery" android:text="..." android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="30dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_cpu_gov"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="CHANGE GOVERNOR"
                android:background="#00E5FF"
                android:textColor="#000000"
                android:textStyle="bold"
                android:layout_marginBottom="15dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_clean_ram"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="BRUTAL RAM CLEAN"
                android:background="#FF1744"
                android:textColor="#FFFFFF"
                android:textStyle="bold" />
        </LinearLayout>
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:text="AUTHORIZED DEVICES ONLY"
            android:textColor="#22FFFFFF"
            android:textSize="9sp"
            android:gravity="center"
            android:letterSpacing="0.2" />

    </LinearLayout>
</ScrollView>
