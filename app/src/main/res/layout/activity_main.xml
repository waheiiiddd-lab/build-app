<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#07090D"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ZIXINE"
            android:textColor="#FFFFFF"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ENGINE CORE"
            android:textColor="#FF1744"
            android:textSize="12sp"
            android:letterSpacing="0.3"
            android:layout_marginBottom="35dp" />

        <LinearLayout
            android:id="@+id/layout_locked"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <EditText
                android:id="@+id/input_code"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:background="#12161F"
                android:hint="ENTER PASSKEY"
                android:textColor="#FFFFFF"
                android:textColorHint="#44FFFFFF"
                android:gravity="center"
                android:inputType="numberPassword"
                android:layout_marginBottom="15dp" />

            <Button
                android:id="@+id/btn_unlock"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="BYPASS SECURITY"
                android:backgroundTint="#FF1744"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layout_verified"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <TextView android:text="RAM STATUS" android:textColor="#88FFFFFF" android:textSize="11sp" />
            <TextView android:id="@+id/tv_ram" android:text="..." android:textColor="#00E5FF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />

            <TextView android:text="ZRAM DISK" android:textColor="#88FFFFFF" android:textSize="11sp" />
            <TextView android:id="@+id/tv_zram" android:text="..." android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />

            <TextView android:text="CPU GOVERNOR" android:textColor="#88FFFFFF" android:textSize="11sp" />
            <TextView android:id="@+id/tv_cpu" android:text="..." android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="12dp" />

            <TextView android:text="BATTERY" android:textColor="#88FFFFFF" android:textSize="11sp" />
            <TextView android:id="@+id/tv_battery" android:text="..." android:textColor="#FFFFFF" android:textSize="20sp" android:textStyle="bold" android:layout_marginBottom="30dp" />

            <Button
                android:id="@+id/btn_cpu_gov"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="SET GOVERNOR"
                android:backgroundTint="#00E5FF"
                android:textColor="#000000"
                android:layout_marginBottom="10dp" />

            <Button
                android:id="@+id/btn_clean_ram"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="BRUTAL RAM CLEAN"
                android:backgroundTint="#FF1744"
                android:textColor="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
